{
  "name": "librooapp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "NUXT_LIBROO_RUNTIME_PROFILE=cloudflare NITRO_PRESET=cloudflare_module nuxt build",
    "build:selfhost": "NUXT_LIBROO_RUNTIME_PROFILE=selfhost NITRO_PRESET=node_server nuxt build",
    "backup:selfhost": "node scripts/backup-selfhost.mjs",
    "restore:selfhost": "node scripts/restore-selfhost.mjs",
    "backup:hosted:manifest": "node scripts/hosted-backup-manifest.mjs",
    "check:cloudflare-size": "pnpm build:cloudflare && pnpm exec wrangler --cwd .output deploy --dry-run --outdir /tmp/libroo-wrangler-dry-run",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run --project unit --project d1 --project integration --project scripts",
    "test:unit": "vitest run --project unit",
    "test:d1": "vitest run --project d1",
    "test:integration": "vitest run --project integration",
    "test:scripts": "vitest run --project scripts",
    "test:e2e": "pnpm build:selfhost && playwright test",
    "test:e2e:run": "playwright test",
    "test:e2e:ui": "pnpm build:selfhost && playwright test --ui"
  },
  "dependencies": {
    "@comark/nuxt": "^0.5.1",
    "@effect/platform": "^0.97.0",
    "@effect/platform-node": "^0.108.0",
    "@iconify-json/lucide": "^1.2.117",
    "@iconify-json/simple-icons": "^1.2.90",
    "@libsql/client": "^0.17.4",
    "@nuxt/hints": "1.1.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.3.1",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.8",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^3.1.8",
    "better-auth": "^1.6.23",
    "comark": "0.5.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.22.0",
    "h3": "1.15.11",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.5.0",
    "pinia": "^3.0.4",
    "sharp": "^0.35.3",
    "vue": "^3.5.39",
    "vue-qrcode-reader": "^5.7.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@libsql/linux-arm64-musl": "0.5.29",
    "@libsql/linux-x64-musl": "0.5.29"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
