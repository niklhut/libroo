{
  "name": "librooapp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "NUXT_LIBROO_RUNTIME_PROFILE=cloudflare NITRO_PRESET=cloudflare_module nuxt build",
    "build:selfhost": "NUXT_LIBROO_RUNTIME_PROFILE=selfhost NITRO_PRESET=node_server nuxt build",
    "check:cloudflare-size": "pnpm build:cloudflare && pnpm exec wrangler --cwd .output deploy --dry-run --outdir /tmp/libroo-wrangler-dry-run",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@iconify-json/lucide": "^1.2.107",
    "@iconify-json/simple-icons": "^1.2.82",
    "@libsql/client": "^0.17.3",
    "@nuxt/hints": "1.1.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.0.6",
    "@nuxt/ui": "^4.7.1",
    "@nuxthub/core": "^0.10.7",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^3.1.0",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.11",
    "nuxt": "^4.4.5",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "vue": "^3.5.34",
    "vue-qrcode-reader": "^5.7.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@libsql/linux-arm64-musl": "0.5.29",
    "@libsql/linux-x64-musl": "0.5.29"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9",
    "wrangler": "4.101.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
