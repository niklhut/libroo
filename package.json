{
  "name": "librooapp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "NUXT_LIBROO_RUNTIME_PROFILE=cloudflare NITRO_PRESET=cloudflare_module nuxt build",
    "build:selfhost": "NUXT_LIBROO_RUNTIME_PROFILE=selfhost NITRO_PRESET=node_server nuxt build",
    "check:cloudflare-size": "pnpm build:cloudflare && pnpm exec wrangler --cwd .output deploy --dry-run --outdir /tmp/libroo-wrangler-dry-run",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@comark/nuxt": "^0.4.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@iconify-json/lucide": "^1.2.113",
    "@iconify-json/simple-icons": "^1.2.86",
    "@libsql/client": "^0.17.4",
    "@nuxt/hints": "1.1.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.2.1",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.7",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^3.1.4",
    "better-auth": "^1.6.19",
    "comark": "0.4.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.3",
    "h3": "1.15.11",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "sharp": "^0.35.1",
    "vue": "^3.5.38",
    "vue-qrcode-reader": "^5.7.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
