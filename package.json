{
  "name": "librooapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "NUXT_LIBROO_RUNTIME_PROFILE=cloudflare NITRO_PRESET=cloudflare_module nuxt build",
    "build:selfhost": "NUXT_LIBROO_RUNTIME_PROFILE=selfhost NITRO_PRESET=node_server nuxt build",
    "backup:selfhost": "node scripts/backup-selfhost.mjs",
    "restore:selfhost": "node scripts/restore-selfhost.mjs",
    "backup:hosted:manifest": "node scripts/hosted-backup-manifest.mjs",
    "check:cloudflare-size": "pnpm build:cloudflare && pnpm exec wrangler --cwd .output deploy --dry-run --outdir /tmp/libroo-wrangler-dry-run",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:d1": "vitest run --project d1",
    "test:integration": "vitest run --project integration",
    "test:e2e": "pnpm build:selfhost && playwright test",
    "test:e2e:run": "playwright test",
    "test:e2e:ui": "pnpm build:selfhost && playwright test --ui"
  },
  "dependencies": {
    "@comark/nuxt": "^0.4.0",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@libsql/client": "^0.17.4",
    "@nuxt/hints": "1.1.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.2.1",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^3.1.6",
    "better-auth": "^1.6.22",
    "comark": "0.4.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.4",
    "h3": "1.15.11",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "sharp": "^0.35.2",
    "vue": "^3.5.39",
    "vue-qrcode-reader": "^5.7.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@libsql/linux-arm64-musl": "0.5.29",
    "@libsql/linux-x64-musl": "0.5.29"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.20",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "wrangler": "4.105.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
