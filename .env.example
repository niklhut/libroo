# Libroo local/self-host defaults.
# Copy to .env for development or Docker Compose:
#   cp .env.example .env
#
# Generate a stable secret:
#   openssl rand -base64 32

# Better Auth configuration. Better Auth's docs call these BETTER_AUTH_SECRET
# and BETTER_AUTH_URL; Libroo reads them through Nuxt runtime config.
NUXT_BETTER_AUTH_SECRET=
NUXT_BETTER_AUTH_URL=http://localhost:3000

# Runtime profile:
# - selfhost: local libSQL/SQLite + local blob storage
# - cloudflare: NuxtHub D1 + NuxtHub/R2 blob storage
NUXT_LIBROO_RUNTIME_PROFILE=selfhost

# Self-hosted runtime only. The Docker image overrides these to /data paths.
NUXT_DATABASE_URL=file:.data/db/sqlite.db
NUXT_LOCAL_STORAGE_DIR=.data/blob
# Optional comma-separated trusted client-IP headers for self-hosted reverse
# proxy deployments only. Leave empty for direct access; Cloudflare profile does
# not require this because it uses cf-connecting-ip automatically.
NUXT_TRUSTED_IP_HEADERS=

# Bulk ISBN protection. The batch cap is shared with the client default (20).
NUXT_BOOKS_BULK_ADD_MAX_COUNT=20
# Best-effort, fixed-window protection for ISBN lookup and add requests.
NUXT_BOOKS_RATE_LIMIT_ENABLED=false
NUXT_BOOKS_RATE_LIMIT_WINDOW_SECONDS=60
NUXT_BOOKS_RATE_LIMIT_MAX_REQUESTS=30

# Registration and Open Library links.
# Leave registration enabled for a new install until the first admin is created.
NUXT_PUBLIC_REGISTRATION_ENABLED=true
# Local development enables source links by default. Production hides them unless
# this override is set to true.
# NUXT_PUBLIC_OPEN_LIBRARY_LINKS_ENABLED=true

# Email is optional. Set verification true only after a sending provider works.
NUXT_EMAIL_VERIFICATION_ENABLED=false

# Optional Cloudflare Turnstile protection for abuse-prone public auth flows.
# Public/hosted installs should enable this before opening signup or password
# reset email to the internet. Private LAN, VPN/Tailscale, Cloudflare Access, or
# otherwise access-controlled installs may intentionally leave it disabled.
NUXT_PUBLIC_TURNSTILE_ENABLED=false
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=
# Optional comma-separated hostname allow-list for issued Turnstile tokens.
# NUXT_TURNSTILE_ALLOWED_HOSTNAMES=libroo.example.com

# SMTP works in the self-hosted profile.
NUXT_EMAIL_PROVIDER=smtp
NUXT_EMAIL_FROM=
NUXT_EMAIL_REPLY_TO=
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_SECURE=false
NUXT_SMTP_USER=
NUXT_SMTP_PASSWORD=

# Plunk works in both profiles and is the hosted Cloudflare email provider.
NUXT_PLUNK_API_KEY=
NUXT_PLUNK_BASE_URL=https://next-api.useplunk.com

# Hosted Cloudflare/NuxtHub build settings. Usually set these in CI or hosting
# secrets instead of a committed env file.
# NUXT_LIBROO_RUNTIME_PROFILE=cloudflare
# NUXT_HUB_CLOUDFLARE_DATABASE_ID=
# NUXT_HUB_CLOUDFLARE_BUCKET_NAME=
# NUXT_CLOUDFLARE_WORKER_NAME=libroo
# NUXT_CLOUDFLARE_CUSTOM_DOMAIN=

# Optional public legal pages. If a public URL is set, the app links/redirects
# to it. Otherwise, set a Markdown source URL that the server fetches and renders
# inside the app. The app does not ship legally sufficient template text.
NUXT_PUBLIC_LEGAL_PRIVACY_POLICY_URL=
NUXT_PUBLIC_LEGAL_IMPRINT_URL=
NUXT_PUBLIC_LEGAL_TERMS_URL=
NUXT_LEGAL_PRIVACY_POLICY_MARKDOWN_URL=
NUXT_LEGAL_IMPRINT_MARKDOWN_URL=
NUXT_LEGAL_TERMS_MARKDOWN_URL=

# Cross-cutting timeouts for external HTTP requests.
NUXT_LEGAL_MARKDOWN_FETCH_TIMEOUT_SECONDS=5
NUXT_OPEN_LIBRARY_COVER_TIMEOUT_SECONDS=20
NUXT_OPEN_LIBRARY_REQUEST_TIMEOUT_SECONDS=12
NUXT_PLUNK_SEND_TIMEOUT_SECONDS=5
