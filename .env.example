NUXT_BETTER_AUTH_SECRET=
NUXT_BETTER_AUTH_URL=http://localhost:3000

# Disabled by default. Set to true for hosted/self-hosted deployments that
# should require users to verify email ownership before normal app access.
NUXT_EMAIL_VERIFICATION_ENABLED=false
NUXT_PUBLIC_REGISTRATION_ENABLED=true
NUXT_EMAIL_PROVIDER=smtp
NUXT_EMAIL_FROM=
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_SECURE=false
NUXT_SMTP_USER=
NUXT_SMTP_PASSWORD=
NUXT_PLUNK_API_KEY=
NUXT_PLUNK_BASE_URL=https://next-api.useplunk.com
