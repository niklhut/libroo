BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Disabled by default. Set to true for hosted/self-hosted deployments that
# should require users to verify email ownership before normal app access.
LIBROO_EMAIL_VERIFICATION_ENABLED=false
LIBROO_PUBLIC_REGISTRATION_ENABLED=true
LIBROO_EMAIL_PROVIDER=smtp
LIBROO_EMAIL_FROM=
LIBROO_SMTP_HOST=
LIBROO_SMTP_PORT=587
LIBROO_SMTP_SECURE=false
LIBROO_SMTP_USER=
LIBROO_SMTP_PASSWORD=
LIBROO_PLUNK_API_KEY=
LIBROO_PLUNK_BASE_URL=https://next-api.useplunk.com
