# Canonical non-production runtime values for disposable Cloudflare previews.
# The workflow adds the per-PR NUXT_BETTER_AUTH_URL after resolving the
# account workers.dev subdomain. NUXT_CLOUDFLARE_CUSTOM_DOMAIN must stay unset.
NUXT_EMAIL_FROM=
NUXT_EMAIL_REPLY_TO=
NUXT_EMAIL_VERIFICATION_ENABLED=false
NUXT_LEGAL_IMPRINT_MARKDOWN_URL=
NUXT_LEGAL_PRIVACY_POLICY_MARKDOWN_URL=
NUXT_LEGAL_TERMS_MARKDOWN_URL=
NUXT_PUBLIC_LEGAL_IMPRINT_URL=
NUXT_PUBLIC_LEGAL_PRIVACY_POLICY_URL=
NUXT_PUBLIC_LEGAL_TERMS_URL=
NUXT_PUBLIC_REGISTRATION_ENABLED=true
NUXT_PUBLIC_TURNSTILE_ENABLED=false
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
NUXT_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
